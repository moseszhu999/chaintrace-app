    "contracts:compile": "hardhat compile",
    "contracts:test": "hardhat test",
    "contracts:deploy:dev": "hardhat run scripts/deploy-dev.js --network hardhat",
    "contracts:deploy:base-sepolia": "hardhat run scripts/deploy-base-sepolia.js --network baseSepolia"
  },
  "dependencies": {
    "@neondatabase/serverless": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "viem": "latest"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.19"
  }

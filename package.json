{
  "name": "chaintrace-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/prepare-vercel-static.cjs && next build",
    "vercel-build": "node scripts/prepare-vercel-static.cjs && next build",
    "contracts:compile": "hardhat compile",
    "contracts:test": "hardhat test",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "viem": "^2.54.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-node-test-runner": "^3.0.17",
    "@nomicfoundation/hardhat-viem": "^3.0.9",
    "@nomicfoundation/hardhat-viem-assertions": "^3.1.1",
    "@types/node": "24.0.10",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "hardhat": "^3.9.0",
    "typescript": "5.8.3",
    "vitest": "3.2.6"
  },
  "overrides": {
    "postcss": "8.5.16",
    "undici": "8.5.0",
    "ws": "8.21.0"
  }
}

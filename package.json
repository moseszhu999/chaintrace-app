{
  "name": "chaintrace-app",
  "version": "0.2.0",
  "private": true,
  "description": "AI-native Trade Evidence Passport platform for real multi-organization trade evidence workflows.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "api:validate": "node scripts/validate-api-contracts.js",
    "ux:validate": "node scripts/validate-public-agent-entry.js",
    "agent:validate": "node scripts/validate-agent-workflow.js",
    "ops:validate": "node scripts/validate-operator-os.js",
    "smoke:evidence": "node scripts/smoke-working-site.js evidence",
    "smoke:case": "node scripts/smoke-working-site.js case",

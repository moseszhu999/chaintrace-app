generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EXPORTER
  BUYER
  LOGISTICS
  INSPECTOR
  BANK
  OPERATOR
  AUDITOR
}

enum CaseStateValue {
  DRAFT_INTENT
  EVIDENCE_PACKAGED
  MULTI_PARTY_PROOFS_READY
  REVIEW_ASSISTANT
  FUNDING_EXECUTION_BLOCKED
}

enum DocumentType {
  PO
  INVOICE
  PACKING_LIST
  BILL_OF_LADING
  INSPECTION_REPORT
  OTHER
}

enum ProofStatus {
  PENDING
  PASSED
  CONDITIONAL
  BLOCKED
}

enum GateType {
  IDENTITY_GATE
  TRADE_EVIDENCE_GATE
  BUYER_OBLIGATION_GATE
  GOODS_CHAIN_GATE
  BANK_REVIEW_GATE
  FUNDING_EXECUTION_GATE
}

enum ProofType {
  TRADE_DOCUMENT
  BUYER_ACK
  PHYSICAL_FACT
  BANK_REVIEW
}

enum BankDecision {
  ALLOW_REVIEW
  REQUEST_MORE_EVIDENCE
  REDUCE_CAP
  REJECT
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  walletAddress  String           @unique
  role           Role
  roleLocked     Boolean          @default(true)
  createdAt      DateTime         @default(now())
  companyProfile CompanyProfile?
  exportedCases  Case[]           @relation("ExporterCases")
  documents      TradeDocument[]  @relation("UploadedDocuments")
  proofNodes     ProofNode[]      @relation("OwnedProofNodes")
  auditLogs      AuditLog[]       @relation("ActorAuditLogs")
  bankReviews    BankReview[]     @relation("ReviewerBankReviews")
}

model CompanyProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  role         Role
  legalName    String
  country      String
  businessType String
  kybStatus    String
  createdAt    DateTime @default(now())
}

model Case {
  id                   String          @id @default(cuid())
  caseNo               String          @unique
  exporterId           String
  exporter             User            @relation("ExporterCases", fields: [exporterId], references: [id])
  buyerName            String
  buyerId              String?
  amount               Decimal
  currency             String
  description          String
  status               CaseStateValue  @default(DRAFT_INTENT)
  currentState         CaseStateValue  @default(DRAFT_INTENT)
  disbursementAllowed  Boolean         @default(false)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  tradeDocuments       TradeDocument[]
  proofNodes           ProofNode[]
  gates                Gate[]
  caseStates           CaseState[]
  auditLogs            AuditLog[]
  bankReviews          BankReview[]
  disputes             Dispute[]
}

model TradeDocument {
  id          String       @id @default(cuid())
  caseId      String
  case        Case         @relation(fields: [caseId], references: [id])
  type        DocumentType
  fileName    String
  fileUrl     String?
  textSummary String
  hash        String
  uploadedBy  String
  uploader    User         @relation("UploadedDocuments", fields: [uploadedBy], references: [id])
  createdAt   DateTime     @default(now())
  proofNodes  ProofNode[]
}

model ProofNode {
  id                 String         @id @default(cuid())
  caseId             String
  case               Case           @relation(fields: [caseId], references: [id])
  proofType          ProofType
  ownerRole          Role
  ownerUserId        String
  owner              User           @relation("OwnedProofNodes", fields: [ownerUserId], references: [id])
  sourceDocumentId   String?
  sourceDocument     TradeDocument? @relation(fields: [sourceDocumentId], references: [id])
  hash               String
  status             ProofStatus
  summary            String
  dependsOnProofIds  String[]
  createdAt          DateTime       @default(now())
}

model Gate {
  id             String      @id @default(cuid())
  caseId         String
  case           Case        @relation(fields: [caseId], references: [id])
  gateType       GateType
  status         ProofStatus
  reason         String
  requiredAction String
  updatedAt      DateTime    @updatedAt
}

model CaseState {
  id                  String         @id @default(cuid())
  caseId              String
  case                Case           @relation(fields: [caseId], references: [id])
  state               CaseStateValue
  explanation         String
  canContinueReview   Boolean
  canExecuteFunding   Boolean        @default(false)
  disbursementAllowed Boolean        @default(false)
  updatedAt           DateTime       @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id])
  actorUserId String
  actor       User     @relation("ActorAuditLogs", fields: [actorUserId], references: [id])
  actorRole   Role
  action      String
  targetType  String
  targetId    String
  summary     String
  createdAt   DateTime @default(now())
}

model BankReview {
  id           String       @id @default(cuid())
  caseId       String
  case         Case         @relation(fields: [caseId], references: [id])
  reviewerId   String
  reviewer     User         @relation("ReviewerBankReviews", fields: [reviewerId], references: [id])
  decision     BankDecision
  suggestedCap Decimal?
  reason       String
  createdAt    DateTime     @default(now())
}

model Dispute {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  type      String
  status    String
  summary   String
  createdBy String
  createdAt DateTime @default(now())
}
